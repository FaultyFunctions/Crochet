{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 120,
	"jsxSingleQuote": true,
	"htmlWhitespaceSensitivity": "ignore",
	"bracketSameLine": false,
	"organizeImportsSkipDestructiveCodeActions": true,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss", "prettier-plugin-organize-imports"],
	"svelteSortOrder": "options-scripts-markup-styles",
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	]
}
